#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if [[ ! -x ".venv/bin/pytest" ]]; then
  echo "[pre-push] Missing .venv/bin/pytest. Run: .venv/bin/pip install -e ." >&2
  exit 1
fi

echo "[pre-push] Running test suite..."
PYTHONWARNINGS=ignore .venv/bin/pytest -q --disable-warnings

LAST_MSG="$(git log -1 --pretty=%s)"
if [[ "$LAST_MSG" =~ ^chore:\ bump\ sheriff\ version\ to\  ]]; then
  echo "[pre-push] Sheriff version already bumped in HEAD; continuing push."
  exit 0
fi

if [[ ! -f versions.json ]]; then
  echo "[pre-push] versions.json not found; cannot bump sheriff version." >&2
  exit 1
fi

NEW_VER="$(python3 - <<'PY'
import json
from pathlib import Path
p = Path('versions.json')
obj = json.loads(p.read_text(encoding='utf-8'))
v = str(obj.get('sheriff', '0.0.0'))
parts = [int(x) for x in v.split('.')[:3]]
while len(parts) < 3:
    parts.append(0)
parts[2] += 1
obj['sheriff'] = f"{parts[0]}.{parts[1]}.{parts[2]}"
p.write_text(json.dumps(obj, ensure_ascii=False, indent=2) + "\n", encoding='utf-8')
print(obj['sheriff'])
PY
)"

git add versions.json
git commit -m "chore: bump sheriff version to ${NEW_VER}" >/dev/null

echo "[pre-push] Bumped sheriff version to ${NEW_VER}."
echo "[pre-push] Push aborted intentionally so the new bump commit is included."
echo "[pre-push] Re-run: git push"
exit 1
